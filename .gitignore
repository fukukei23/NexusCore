# フォルダ名: C:\Users\USER\tools\NexusCore
# ファイル名: .gitignore

# --- Secrets ---
# APIキーやパスワードなどの秘密情報
.env
!.env.template
# secrets.py は追跡しない
src/nexuscore/config/secrets.py

# Kubernetes Secrets（機密情報を含むため除外）
k8s/nexuscore-secrets.yaml
k8s/*-secrets.yaml
k8s/*.secret.yaml

# --- Byte-compiled / optimized / DLL files ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Build / Generated outputs ---
build/
dist/
*.egg-info/
exports/

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-error.log*

# --- Python ---
.venv/
venv/
myenv_linux/
ENV/
env/
env.bak/
venv.bak/
__pycache__/
*.pyc

# --- Django specific ---
# 開発用データベース
db.sqlite3


# --- Flask specific ---
# Flask instance folder
instance/
src/instance/
*.db

# --- SDK generated files ---
sdk/python/
# TypeScript SDK: ソースは追跡、ビルド成果物のみ無視
sdk/typescript/dist/
sdk/typescript/node_modules/
!sdk/.gitkeep


# --- Project-specific ignores ---
# 生成されたファイルが出力されるフォルダ
output/*
!output/core_files.txt

# VSCode settings
.vscode/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# ----------------------------------
# Git LFSで管理しない場合は以下の行を残す
# **/combined_code.txt
# ----------------------------------

# coverage / テスト結果
.coverage
.coverage-phase3
coverage.xml
coverage.json
htmlcov/
.pytest_cache/
.mypy_cache/

# mutmut (mutation testing)
mutants/
.mutmut-cache
.mutmut_temp.toml

# テスト結果ファイル（自動生成）
docs/reports/TEST_RESULTS_*.txt
docs/reports/TEST_ERRORS_*.txt

# ログ（logs/ ディレクトリ内のファイルは追跡しないが、ディレクトリ自体は保持）
logs/*
!logs/.gitkeep
# 後方互換性のため、ルートのログファイルも除外
nexus_api_server.log
nexus_core_run.log
project_chronicle.jsonl
*.log

# --- Archives / Backups ---
*.zip
*.tar.gz
*.rar
*.7z
*.bak
*.tmp

# Kubernetes バイナリ（サイズが大きいため）
kubectl
minikube-linux-amd64

# ローカルデータベース
nexus_local.db
