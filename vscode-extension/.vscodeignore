# ==============================================================================
# フォルダ: vscode-extension
# ファイル名: .vscodeignore
# メモ: VSCode拡張機能をパッケージ化する際に含めないファイルやフォルダを指定。
#      これにより、最終的なパッケージサイズを軽量に保ち、不要な情報が
#      含まれるのを防ぎます。
# ==============================================================================

# 依存関係はパッケージに含めない (インストール時に自動で解決される)
node_modules
.vscode-test/

# ソースファイルはコンパイル後のdist/に含まれるため、元のソースは不要
src/

# 設定ファイルやテスト関連
.eslintrc.json
tsconfig.json
webpack.config.js
*.map

# OS固有のファイル
.DS_Store
Thumbs.db

# Git関連
.git
.gitignore

# その他
*.log
.env
