{
  "folders": [
    {
      "path": "."
    }
  ],
  "settings": {
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "files.exclude": {
      "**/__pycache__": true
    }
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "🟢 開発用 UI 起動 (launch_dev.ps1)",
        "type": "shell",
        "command": "powershell",
        "args": [
          "-NoExit",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}/launch_dev.ps1"
        ],
        "problemMatcher": [],
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "presentation": {
          "reveal": "always",
          "panel": "shared"
        }
      },
      {
        "label": "🟡 Streamlit (旧UI)",
        "type": "shell",
        "command": "powershell",
        "args": [
          "-NoExit",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}/launch_streamlit_legacy.ps1"
        ],
        "problemMatcher": [],
        "group": "build",
        "presentation": {
          "reveal": "always",
          "panel": "shared"
        }
      }
    ]
  }
}
