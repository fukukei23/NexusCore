{
  "includes": [
    "src",
    "tests",
    "app",
    "tools",
    "evaluation",
    "exports",
    "dev_tools"
  ],
  "excludes": [
    ".git",
    ".venv",
    "__pycache__",
    "node_modules",
    "build",
    "dist",
    ".logs",
    ".gradio",
    "exports/_imports",
    "exported_projects",
    "sandbox_output",
    "deploy_output",
    "output",
    "*.zip",
    "*.7z",
    "*.log",
    "*.png",
    "*.jpg",
    "*.gif",
    "*.onnx",
    "*.pb",
    "*.pbtxt",
    "*.tar",
    "*.gz"
  ],
  "max_file_size_mb": 2,
  "use_git_if_available": true,
  "chronicle_path": "logs/project_chronicle.jsonl",
  "state_path": ".nexus_state.json",
  "try_integrated_summary": true,
  "default_mode": "auto",
  "auto_bootstrap": true
}
